<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Aurora backdrop (base gradient) -->
    <View
        android:id="@+id/aurora_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/aurora_light" />

    <!-- Animated aurora orbs -->
    <View
        android:id="@+id/aurora_orb1"
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:layout_marginStart="-100dp"
        android:layout_marginTop="-200dp"
        android:background="@drawable/aurora_orb_1" />

    <View
        android:id="@+id/aurora_orb2"
        android:layout_width="700dp"
        android:layout_height="700dp"
        android:layout_gravity="end"
        android:layout_marginEnd="-150dp"
        android:layout_marginTop="-100dp"
        android:background="@drawable/aurora_orb_2" />

    <View
        android:id="@+id/aurora_orb3"
        android:layout_width="800dp"
        android:layout_height="800dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="-400dp"
        android:background="@drawable/aurora_orb_3" />

    <!-- Floating paw prints -->
    <FrameLayout
        android:id="@+id/paw_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false" />

    <!-- Safety alert pill (top center, hidden by default) -->
    <LinearLayout
        android:id="@+id/safety_alert"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/safety_alert_bg"
        android:elevation="@dimen/elevation_2"
        android:paddingStart="@dimen/alert_padding_h"
        android:paddingEnd="@dimen/alert_padding_h"
        android:paddingTop="@dimen/alert_padding_v"
        android:paddingBottom="@dimen/alert_padding_v"
        android:visibility="gone">

        <ImageView
            android:layout_width="@dimen/icon_alert"
            android:layout_height="@dimen/icon_alert"
            android:src="@drawable/ic_warning"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/safety_alert_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alert_ac_off"
            android:textSize="@dimen/text_safety_alert"
            android:textColor="#FFFFFFFF"
            android:fontFamily="sans-serif-bold"
            android:letterSpacing="0.04"
            android:textAllCaps="true" />
    </LinearLayout>

    <!-- Top chrome: outside temp pill (left) + settings btn (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="@dimen/content_padding_v"
        android:paddingStart="@dimen/content_padding_h"
        android:paddingEnd="@dimen/content_padding_h">

        <!-- Outside temperature pill -->
        <LinearLayout
            android:id="@+id/outside_temp_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/glass_pill"
            android:elevation="@dimen/elevation_1"
            android:paddingStart="@dimen/pill_padding_h"
            android:paddingEnd="@dimen/pill_padding_h"
            android:paddingTop="@dimen/pill_padding_v"
            android:paddingBottom="@dimen/pill_padding_v">

            <ImageView
                android:id="@+id/outside_temp_icon"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/ic_clock"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/outside_temp_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_body_l"
                android:textColor="@color/fg_primary"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Settings button -->
        <FrameLayout
            android:id="@+id/settings_btn"
            android:layout_width="@dimen/chrome_btn_size"
            android:layout_height="@dimen/chrome_btn_size"
            android:background="@drawable/glass_chrome_btn"
            android:elevation="@dimen/elevation_1">

            <ImageView
                android:id="@+id/settings_icon"
                android:layout_width="@dimen/icon_chrome"
                android:layout_height="@dimen/icon_chrome"
                android:layout_gravity="center"
                android:src="@drawable/ic_settings"
                android:tint="@color/slate_700" />
        </FrameLayout>
    </LinearLayout>

    <!-- Main content: temp (left) + avatar/message (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="@dimen/content_padding_h"
        android:paddingEnd="@dimen/content_padding_h"
        android:paddingTop="@dimen/space_8"
        android:paddingBottom="@dimen/space_9">

        <!-- Left: Temperature display -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <TextView
                    android:id="@+id/temperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="@dimen/text_display_xl"
                    android:textColor="@color/fg_primary"
                    android:fontFamily="sans-serif-thin"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/temp_unit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="°C"
                    android:textSize="@dimen/text_temp_unit"
                    android:textColor="@color/fg_secondary"
                    android:fontFamily="sans-serif-thin"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="18dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/ac_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/set_temperature"
                android:textSize="@dimen/text_temp_sub"
                android:textColor="@color/fg_secondary"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:layout_marginTop="3dp"
                android:visibility="visible" />
        </LinearLayout>

        <!-- Right: Avatar + Reassurance -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Glass avatar disc -->
            <FrameLayout
                android:id="@+id/avatar_disc"
                android:layout_width="@dimen/avatar_disc_size"
                android:layout_height="@dimen/avatar_disc_size"
                android:background="@drawable/glass_avatar_disc"
                android:elevation="@dimen/elevation_2">

                <ImageView
                    android:id="@+id/avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/avatar_paw"
                    android:scaleType="centerInside"
                    android:padding="16dp" />

                <View
                    android:id="@+id/avatar_specular"
                    android:layout_width="110dp"
                    android:layout_height="60dp"
                    android:layout_gravity="top|start"
                    android:layout_marginTop="18dp"
                    android:layout_marginStart="38dp"
                    android:background="@drawable/avatar_specular"
                    android:alpha="0.7" />
            </FrameLayout>

            <!-- Reassurance message -->
            <TextView
                android:id="@+id/message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_reassure_msg"
                android:textColor="@color/fg_primary"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:layout_marginTop="18dp"
                android:maxWidth="400dp" />

            <TextView
                android:id="@+id/sub_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_reassure_sub"
                android:textColor="@color/fg_secondary"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:layout_marginTop="10dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Status bar capsule (bottom center) -->
    <LinearLayout
        android:id="@+id/status_capsule"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="20dp"
        android:orientation="horizontal"
        android:background="@drawable/glass_status_capsule"
        android:elevation="@dimen/elevation_2"
        android:padding="@dimen/status_bar_padding">

        <!-- AC status item -->
        <LinearLayout
            android:id="@+id/status_item_ac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/glass_status_item_active"
            android:paddingStart="@dimen/status_bar_item_padding_h"
            android:paddingEnd="@dimen/status_bar_item_padding_h"
            android:paddingTop="@dimen/status_bar_item_padding_v"
            android:paddingBottom="@dimen/status_bar_item_padding_v"
            android:layout_marginEnd="@dimen/space_1">

            <ImageView
                android:id="@+id/status_icon_ac"
                android:layout_width="@dimen/icon_status"
                android:layout_height="@dimen/icon_status"
                android:src="@drawable/ic_snowflake"
                android:layout_marginEnd="@dimen/status_bar_item_gap"
                android:alpha="0.7" />

            <TextView
                android:id="@+id/status_ac"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_status"
                android:textColor="@color/fg_primary"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Doors status item -->
        <LinearLayout
            android:id="@+id/status_item_doors"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/status_bar_item_padding_h"
            android:paddingEnd="@dimen/status_bar_item_padding_h"
            android:paddingTop="@dimen/status_bar_item_padding_v"
            android:paddingBottom="@dimen/status_bar_item_padding_v"
            android:layout_marginEnd="@dimen/space_1">

            <ImageView
                android:id="@+id/status_icon_doors"
                android:layout_width="@dimen/icon_status"
                android:layout_height="@dimen/icon_status"
                android:src="@drawable/ic_lock"
                android:layout_marginEnd="@dimen/status_bar_item_gap"
                android:alpha="0.7" />

            <TextView
                android:id="@+id/status_doors"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_status"
                android:textColor="@color/fg_primary"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Battery status item -->
        <LinearLayout
            android:id="@+id/status_item_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/status_bar_item_padding_h"
            android:paddingEnd="@dimen/status_bar_item_padding_h"
            android:paddingTop="@dimen/status_bar_item_padding_v"
            android:paddingBottom="@dimen/status_bar_item_padding_v"
            android:layout_marginEnd="@dimen/space_1">

            <ImageView
                android:id="@+id/status_icon_battery"
                android:layout_width="@dimen/icon_status"
                android:layout_height="@dimen/icon_status"
                android:src="@drawable/ic_battery"
                android:layout_marginEnd="@dimen/status_bar_item_gap"
                android:alpha="0.7" />

            <TextView
                android:id="@+id/status_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_status"
                android:textColor="@color/fg_primary"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Timer status item -->
        <LinearLayout
            android:id="@+id/status_item_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/status_bar_item_padding_h"
            android:paddingEnd="@dimen/status_bar_item_padding_h"
            android:paddingTop="@dimen/status_bar_item_padding_v"
            android:paddingBottom="@dimen/status_bar_item_padding_v">

            <ImageView
                android:id="@+id/status_icon_timer"
                android:layout_width="@dimen/icon_status"
                android:layout_height="@dimen/icon_status"
                android:src="@drawable/ic_clock"
                android:layout_marginEnd="@dimen/status_bar_item_gap"
                android:alpha="0.7" />

            <TextView
                android:id="@+id/status_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_status"
                android:textColor="@color/fg_primary"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>

    <!-- Exit button (bottom right) -->
    <TextView
        android:id="@+id/exit_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/content_padding_h"
        android:layout_marginBottom="28dp"
        android:text="@string/exit_im_back"
        android:textSize="@dimen/text_body"
        android:textColor="@color/fg_primary"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/glass_exit_btn"
        android:elevation="@dimen/elevation_1"
        android:paddingStart="@dimen/exit_btn_padding_h"
        android:paddingEnd="@dimen/exit_btn_padding_h"
        android:paddingTop="@dimen/exit_btn_padding_v"
        android:paddingBottom="@dimen/exit_btn_padding_v" />

    <!-- Exit confirm sheet overlay -->
    <FrameLayout
        android:id="@+id/exit_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/exit_sheet"
            android:layout_width="560dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/glass_sheet"
            android:elevation="@dimen/elevation_3"
            android:padding="40dp">

            <TextView
                android:id="@+id/sheet_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/exit_confirm_title"
                android:textSize="@dimen/text_h3"
                android:textColor="@color/fg_primary"
                android:fontFamily="sans-serif-bold" />

            <TextView
                android:id="@+id/sheet_body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/exit_confirm"
                android:textSize="@dimen/text_body"
                android:textColor="@color/fg_secondary"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="28dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/sheet_btn_stay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sheet_stay"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/fg_primary"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/btn_ghost"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/sheet_btn_exit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exit_im_back"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/fg_on_brand"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/btn_primary"
                    android:elevation="@dimen/elevation_1"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
