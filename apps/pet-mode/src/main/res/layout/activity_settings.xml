<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Aurora backdrop -->
    <View
        android:id="@+id/aurora_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/aurora_light" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/content_padding_h"
        android:paddingEnd="@dimen/content_padding_h"
        android:paddingTop="@dimen/content_padding_v"
        android:paddingBottom="@dimen/content_padding_v">

        <!-- Header: Back + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/space_5">

            <FrameLayout
                android:id="@+id/back_btn"
                android:layout_width="@dimen/chrome_btn_size"
                android:layout_height="@dimen/chrome_btn_size"
                android:background="@drawable/glass_chrome_btn"
                android:elevation="@dimen/elevation_1">

                <ImageView
                    android:layout_width="@dimen/icon_chrome"
                    android:layout_height="@dimen/icon_chrome"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_back"
                    android:tint="@color/slate_700" />
            </FrameLayout>

            <TextView
                android:id="@+id/settings_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                android:textSize="@dimen/text_h2"
                android:textColor="@color/fg_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="@dimen/space_5" />
        </LinearLayout>

        <!-- Two-column body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- LEFT COLUMN: Name + Avatar -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="@dimen/space_5">

                <!-- Pet Name row -->
                <LinearLayout
                    android:id="@+id/row_pet_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_setting_row"
                    android:elevation="@dimen/elevation_1"
                    android:padding="@dimen/setting_row_padding_h"
                    android:layout_marginBottom="@dimen/space_3">

                    <TextView
                        android:id="@+id/label_pet_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_pet_name"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/fg_secondary"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="@dimen/space_3" />

                    <EditText
                        android:id="@+id/pet_name_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/glass_input"
                        android:paddingStart="@dimen/input_padding_h"
                        android:paddingEnd="@dimen/input_padding_h"
                        android:paddingTop="@dimen/input_padding_v"
                        android:paddingBottom="@dimen/input_padding_v"
                        android:textSize="@dimen/text_body_l"
                        android:textColor="@color/fg_primary"
                        android:fontFamily="sans-serif-medium"
                        android:singleLine="true" />
                </LinearLayout>

                <!-- Avatar row -->
                <LinearLayout
                    android:id="@+id/row_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_setting_row"
                    android:elevation="@dimen/elevation_1"
                    android:padding="@dimen/setting_row_padding_h">

                    <TextView
                        android:id="@+id/label_avatar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_avatar"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/fg_secondary"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="@dimen/space_4" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Paw tile -->
                        <LinearLayout
                            android:id="@+id/avatar_paw"
                            android:layout_width="@dimen/avatar_tile_size"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="@dimen/space_3"
                            android:layout_marginEnd="@dimen/space_3">

                            <FrameLayout
                                android:layout_width="@dimen/avatar_tile_img_size"
                                android:layout_height="@dimen/avatar_tile_img_size">
                                <View
                                    android:id="@+id/avatar_paw_border"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/glass_avatar_tile" />
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/avatar_paw"
                                    android:scaleType="centerInside"
                                    android:padding="8dp" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/label_paw"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/avatar_paw"
                                android:textSize="@dimen/text_body_s"
                                android:textColor="@color/fg_secondary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="@dimen/space_2" />
                        </LinearLayout>

                        <!-- Dog tile -->
                        <LinearLayout
                            android:id="@+id/avatar_dog"
                            android:layout_width="@dimen/avatar_tile_size"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="@dimen/space_3"
                            android:layout_marginEnd="@dimen/space_3">

                            <FrameLayout
                                android:layout_width="@dimen/avatar_tile_img_size"
                                android:layout_height="@dimen/avatar_tile_img_size">
                                <View
                                    android:id="@+id/avatar_dog_border"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/glass_avatar_tile" />
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/avatar_dog"
                                    android:scaleType="centerInside"
                                    android:padding="8dp" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/label_dog"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/avatar_dog"
                                android:textSize="@dimen/text_body_s"
                                android:textColor="@color/fg_secondary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="@dimen/space_2" />
                        </LinearLayout>

                        <!-- Cat tile -->
                        <LinearLayout
                            android:id="@+id/avatar_cat"
                            android:layout_width="@dimen/avatar_tile_size"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="@dimen/space_3">

                            <FrameLayout
                                android:layout_width="@dimen/avatar_tile_img_size"
                                android:layout_height="@dimen/avatar_tile_img_size">
                                <View
                                    android:id="@+id/avatar_cat_border"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/glass_avatar_tile" />
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/avatar_cat"
                                    android:scaleType="centerInside"
                                    android:padding="8dp" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/label_cat"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/avatar_cat"
                                android:textSize="@dimen/text_body_s"
                                android:textColor="@color/fg_secondary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="@dimen/space_2" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- RIGHT COLUMN: Unit + Theme + Version -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Temperature unit row -->
                <LinearLayout
                    android:id="@+id/row_temp_unit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/glass_setting_row"
                    android:elevation="@dimen/elevation_1"
                    android:paddingStart="@dimen/setting_row_padding_h"
                    android:paddingEnd="@dimen/setting_row_padding_h"
                    android:paddingTop="@dimen/setting_row_padding_v"
                    android:paddingBottom="@dimen/setting_row_padding_v"
                    android:layout_marginBottom="@dimen/space_3">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/label_temp_unit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_temp_unit"
                            android:textSize="@dimen/text_h4"
                            android:textColor="@color/fg_primary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/label_temp_unit_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_temp_unit_desc"
                            android:textSize="@dimen/text_body_s"
                            android:textColor="@color/fg_secondary" />
                    </LinearLayout>

                    <!-- Segmented control -->
                    <LinearLayout
                        android:id="@+id/temp_unit_group"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/glass_segmented_bg"
                        android:padding="@dimen/segmented_padding">

                        <TextView
                            android:id="@+id/unit_celsius"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="°C"
                            android:textSize="@dimen/text_body"
                            android:textColor="@color/fg_primary"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/glass_segmented_active"
                            android:paddingStart="@dimen/segmented_btn_padding_h"
                            android:paddingEnd="@dimen/segmented_btn_padding_h"
                            android:paddingTop="@dimen/segmented_btn_padding_v"
                            android:paddingBottom="@dimen/segmented_btn_padding_v" />

                        <TextView
                            android:id="@+id/unit_fahrenheit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="°F"
                            android:textSize="@dimen/text_body"
                            android:textColor="@color/fg_secondary"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="@dimen/segmented_btn_padding_h"
                            android:paddingEnd="@dimen/segmented_btn_padding_h"
                            android:paddingTop="@dimen/segmented_btn_padding_v"
                            android:paddingBottom="@dimen/segmented_btn_padding_v" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Dark mode row -->
                <LinearLayout
                    android:id="@+id/row_dark_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/glass_setting_row"
                    android:elevation="@dimen/elevation_1"
                    android:paddingStart="@dimen/setting_row_padding_h"
                    android:paddingEnd="@dimen/setting_row_padding_h"
                    android:paddingTop="@dimen/setting_row_padding_v"
                    android:paddingBottom="@dimen/setting_row_padding_v"
                    android:layout_marginBottom="@dimen/space_3">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/label_dark_mode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_dark_mode"
                            android:textSize="@dimen/text_h4"
                            android:textColor="@color/fg_primary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/label_dark_mode_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_dark_mode_desc"
                            android:textSize="@dimen/text_body_s"
                            android:textColor="@color/fg_secondary" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/theme_toggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumb="@drawable/glass_switch_thumb"
                        android:track="@drawable/glass_switch_track_off" />
                </LinearLayout>

                <!-- Version info -->
                <TextView
                    android:id="@+id/label_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_version"
                    android:textSize="@dimen/text_micro"
                    android:textColor="@color/fg_tertiary"
                    android:layout_marginStart="@dimen/space_2"
                    android:layout_marginTop="@dimen/space_4" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
