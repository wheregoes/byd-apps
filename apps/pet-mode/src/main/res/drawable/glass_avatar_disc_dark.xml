<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="140dp"
                android:centerX="0.3"
                android:centerY="0.25"
                android:startColor="#2EFFFFFF"
                android:centerColor="#0AFFFFFF"
                android:endColor="#0FFFFFFF" />
            <stroke android:width="1dp" android:color="@color/glass_dark_stroke" />
        </shape>
    </item>
</layer-list>
