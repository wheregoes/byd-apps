<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Aurora backdrop -->
    <View
        android:id="@+id/aurora_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/aurora_dark" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/content_padding_h"
        android:paddingEnd="@dimen/content_padding_h"
        android:paddingTop="@dimen/content_padding_v"
        android:paddingBottom="@dimen/content_padding_v">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/space_5">

            <FrameLayout
                android:id="@+id/back_btn"
                android:layout_width="@dimen/chrome_btn_size"
                android:layout_height="@dimen/chrome_btn_size"
                android:background="@drawable/glass_chrome_btn"
                android:elevation="@dimen/elevation_1">

                <ImageView
                    android:layout_width="@dimen/icon_chrome"
                    android:layout_height="@dimen/icon_chrome"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_back"
                    android:tint="#FFFFFFFF" />
            </FrameLayout>

            <TextView
                android:id="@+id/settings_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                android:textSize="@dimen/text_h2"
                android:textColor="#FFFFFFFF"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="@dimen/space_5" />
        </LinearLayout>

        <!-- Two-column body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- LEFT COLUMN -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="@dimen/space_5">

                <!-- Battery alarm threshold -->
                <LinearLayout
                    android:id="@+id/row_battery_threshold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_setting_row_dark"
                    android:elevation="@dimen/elevation_1"
                    android:padding="@dimen/setting_row_padding_h"
                    android:layout_marginBottom="@dimen/space_3">

                    <TextView
                        android:id="@+id/label_battery_threshold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_battery_threshold"
                        android:textSize="@dimen/text_h4"
                        android:textColor="#FFFFFFFF"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/label_battery_threshold_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_battery_threshold_desc"
                        android:textSize="@dimen/text_body_s"
                        android:textColor="#B8FFFFFF"
                        android:layout_marginBottom="@dimen/space_3" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <SeekBar
                            android:id="@+id/battery_threshold_slider"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:min="5"
                            android:max="50"
                            android:progress="20" />

                        <TextView
                            android:id="@+id/battery_threshold_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="20%"
                            android:textSize="@dimen/text_body_l"
                            android:textColor="#FFFFFFFF"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="@dimen/space_3" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Energy cost -->
                <LinearLayout
                    android:id="@+id/row_energy_cost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_setting_row_dark"
                    android:elevation="@dimen/elevation_1"
                    android:padding="@dimen/setting_row_padding_h"
                    android:layout_marginBottom="@dimen/space_3">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_energy_cost"
                        android:textSize="@dimen/text_h4"
                        android:textColor="#FFFFFFFF"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_energy_cost_desc"
                        android:textSize="@dimen/text_body_s"
                        android:textColor="#B8FFFFFF"
                        android:layout_marginBottom="@dimen/space_3" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/energy_cost_input"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/glass_input_dark"
                            android:paddingStart="@dimen/input_padding_h"
                            android:paddingEnd="@dimen/input_padding_h"
                            android:paddingTop="@dimen/input_padding_v"
                            android:paddingBottom="@dimen/input_padding_v"
                            android:textSize="@dimen/text_body_l"
                            android:textColor="#FFFFFFFF"
                            android:hint="0.00"
                            android:hintTextColor="#73FFFFFF"
                            android:inputType="numberDecimal"
                            android:fontFamily="sans-serif-medium"
                            android:singleLine="true" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_energy_cost_unit"
                            android:textSize="@dimen/text_body"
                            android:textColor="#B8FFFFFF"
                            android:layout_marginStart="@dimen/space_3" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- RIGHT COLUMN -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Temperature unit -->
                <LinearLayout
                    android:id="@+id/row_temp_unit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/glass_setting_row_dark"
                    android:elevation="@dimen/elevation_1"
                    android:paddingStart="@dimen/setting_row_padding_h"
                    android:paddingEnd="@dimen/setting_row_padding_h"
                    android:paddingTop="@dimen/setting_row_padding_v"
                    android:paddingBottom="@dimen/setting_row_padding_v"
                    android:layout_marginBottom="@dimen/space_3">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_temp_unit"
                            android:textSize="@dimen/text_h4"
                            android:textColor="#FFFFFFFF"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_temp_unit_desc"
                            android:textSize="@dimen/text_body_s"
                            android:textColor="#B8FFFFFF" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/temp_unit_group"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/glass_segmented_bg_dark"
                        android:padding="@dimen/segmented_padding">

                        <TextView
                            android:id="@+id/unit_celsius"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="°C"
                            android:textSize="@dimen/text_body"
                            android:textColor="#FFFFFFFF"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/glass_segmented_active_dark"
                            android:paddingStart="@dimen/segmented_btn_padding_h"
                            android:paddingEnd="@dimen/segmented_btn_padding_h"
                            android:paddingTop="@dimen/segmented_btn_padding_v"
                            android:paddingBottom="@dimen/segmented_btn_padding_v" />

                        <TextView
                            android:id="@+id/unit_fahrenheit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="°F"
                            android:textSize="@dimen/text_body"
                            android:textColor="#B8FFFFFF"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="@dimen/segmented_btn_padding_h"
                            android:paddingEnd="@dimen/segmented_btn_padding_h"
                            android:paddingTop="@dimen/segmented_btn_padding_v"
                            android:paddingBottom="@dimen/segmented_btn_padding_v" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Screen brightness -->
                <LinearLayout
                    android:id="@+id/row_brightness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_setting_row_dark"
                    android:elevation="@dimen/elevation_1"
                    android:padding="@dimen/setting_row_padding_h"
                    android:layout_marginBottom="@dimen/space_3">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_brightness"
                        android:textSize="@dimen/text_h4"
                        android:textColor="#FFFFFFFF"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_brightness_desc"
                        android:textSize="@dimen/text_body_s"
                        android:textColor="#B8FFFFFF"
                        android:layout_marginBottom="@dimen/space_3" />

                    <SeekBar
                        android:id="@+id/brightness_slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:min="10"
                        android:max="255"
                        android:progress="80" />
                </LinearLayout>

                <!-- Version -->
                <TextView
                    android:id="@+id/label_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_version"
                    android:textSize="@dimen/text_micro"
                    android:textColor="#73FFFFFF"
                    android:layout_marginStart="@dimen/space_2"
                    android:layout_marginTop="@dimen/space_4" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
